{
  "name": "@mosvera/mcp",
  "version": "0.1.6",
  "description": "Run Mosvera as local MCP tools for agents, editors, and Claude Desktop.",
  "license": "Apache-2.0",
  "type": "module",
  "homepage": "https://mosvera.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mosvera/mcp.git"
  },
  "bugs": {
    "url": "https://github.com/mosvera/mcp/issues"
  },
  "keywords": [
    "mosvera",
    "mcp",
    "model-context-protocol",
    "aesthetic-infrastructure",
    "ai"
  ],
  "files": [
    "dist",
    "examples",
    "mcpb",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "mosvera-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json && node scripts/copy-example-registry.mjs",
    "ci": "npm run build && npm run typecheck && npm test",
    "clean": "rm -rf dist",
    "mcpb:stage": "npm run build && node scripts/stage-mcpb.mjs",
    "mcpb:pack": "npm run mcpb:stage && mcpb pack build/mcpb/mosvera build/mosvera/mosvera-mcp-0.1.6.mcpb",
    "mcpb:inspect": "node scripts/inspect-mcpb.mjs build/mosvera/mosvera-mcp-0.1.6.mcpb",
    "prepublishOnly": "npm run build && npm run typecheck && npm test",
    "start": "tsx src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mosvera/runtime": "^0.1.2",
    "@mosvera/provider-base": "^0.1.1",
    "@mosvera/provider-flux": "^0.1.1",
    "@mosvera/provider-openai": "^0.1.1",
    "@mosvera/provider-sdxl": "^0.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.1"
  },
  "optionalDependencies": {
    "@mosvera/provider-elevenlabs": "^0.1.2",
    "@mosvera/provider-firefly": "^0.1.2",
    "@mosvera/provider-google": "^0.1.2",
    "@mosvera/provider-heygen": "^0.1.1",
    "@mosvera/provider-meshy": "^0.1.2",
    "@mosvera/provider-runway": "^0.1.2"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7",
    "tsx": "^4.19.2",
    "@types/node": "^22.10.2"
  }
}
