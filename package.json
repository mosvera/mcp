{
  "name": "@mosvera/mcp",
  "version": "0.1.0",
  "description": "Reference MCP server for Mosvera. Exposes the runtime's resolve/compile/validate capabilities as strict MCP tools over stdio.",
  "license": "Apache-2.0",
  "type": "module",
  "homepage": "https://mosvera.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mosvera/mcp.git"
  },
  "bugs": {
    "url": "https://github.com/mosvera/mcp/issues"
  },
  "keywords": [
    "mosvera",
    "mcp",
    "model-context-protocol",
    "aesthetic-infrastructure",
    "ai"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "mosvera-mcp": "./dist/server.js"
  },
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json && node scripts/copy-example-registry.mjs",
    "ci": "npm run build && npm run typecheck && npm test",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build && npm run typecheck && npm test",
    "start": "tsx src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mosvera/runtime": "^0.1.0",
    "@mosvera/provider-base": "^0.1.0",
    "@mosvera/provider-flux": "^0.1.0",
    "@mosvera/provider-openai": "^0.1.0",
    "@mosvera/provider-sdxl": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^4.1.7",
    "tsx": "^4.19.2",
    "@types/node": "^22.10.2"
  }
}
